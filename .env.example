# =============================================================================
# MedVQA — API Keys / Environment Variables
# =============================================================================
# Copy this file to .env and fill in the API key for your chosen provider.
#
#   cp .env.example .env
#
# Only the provider you plan to use needs to be set.
#
# ── OpenAI ───────────────────────────────────────────────────────────────────
# Models: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-4-vision-preview
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."

# ── Anthropic ────────────────────────────────────────────────────────────────
# Models: claude-3-5-sonnet-20241022, claude-3-opus-20240229, claude-3-haiku
# Get key at: https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-..."

# ── Google Gemini ────────────────────────────────────────────────────────────
# Models: gemini-1.5-pro, gemini-1.5-flash
# Get key at: https://aistudio.google.com/apikey
GEMINI_API_KEY="AIza..."

# ── Local (Ollama) — no API key needed ──────────────────────────────────────
# Models: llava, bakllava (image-capable), or any text model
# Download from: https://ollama.com/
# Start with: ollama pull llava
# OLLAMA_BASE_URL defaults to http://localhost:11434
# OLLAMA_BASE_URL="http://localhost:11434"
